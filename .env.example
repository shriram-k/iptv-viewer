# ── v2 data pipeline (pipeline/src/run.js) ──────────────────────────────────
# Cloudflare KV publish credentials. In CI these are GitHub Actions secrets, not
# a committed file. With none set, `npm run pipeline` runs as a dry-run (builds +
# writes the snapshot locally, skips the KV publish).
#
# Required together to publish to KV (cf-kv.js validates and errors clearly if a
# required one is missing):
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# Optional — enables the post-publish edge cache purge. If unset, the cache TTL
# bounds staleness instead (purge is best-effort, never fatal).
CF_ZONE_ID=

# ── Firebase ────────────────────────────────────────────────────────────────
# GA4 Analytics + Remote Config only, on the free Spark plan (no billing account
# enabled — keeps the project unbillable by construction). No server-side secret
# is required; the web client config is public and lives in the app code.
